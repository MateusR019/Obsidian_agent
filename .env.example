# === Geral ===
APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# === Vault ===
VAULT_PATH=./vault
VAULT_GIT_REMOTE=
VAULT_GIT_BRANCH=main

# === Banco ===
DB_PATH=./data/data.db

# === Autorização WhatsApp ===
ALLOWED_NUMBERS=5511999999999
WEBHOOK_SECRET=

# === Evolution API ===
EVOLUTION_URL=http://localhost:8080
EVOLUTION_INSTANCE=segundo-cerebro
EVOLUTION_API_KEY=

# === Provider LLM ===
LLM_PROVIDER=gemini
LLM_MODEL=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === Provider STT ===
STT_PROVIDER=groq
STT_MODEL=

# === Provider Embedding ===
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=
EMBEDDING_DIMENSION=768

# === Agente ===
AGENT_MAX_TOOL_ITERATIONS=5
AGENT_HISTORY_WINDOW=20
AGENT_TEMPERATURE=0.3
